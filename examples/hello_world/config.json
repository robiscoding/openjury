{
  "name": "Hello World Jury",
  "description": "Minimal jury for the offline quickstart example",
  "score_scale": 5,
  "assertion_policy": {
    "quality_threshold": 4.0
  },
  "contested_threshold": 0.6,
  "llm_provider": {
    "provider": "openai_compatible",
    "model_name": "gpt-4o-mini",
    "api_key": "${OPENAI_API_KEY}"
  },
  "jurors": [
    {
      "name": "Expert Juror",
      "weight": 2.0,
      "temperature": 0.1
    },
    {
      "name": "General Juror",
      "weight": 1.0,
      "temperature": 0.2
    }
  ],
  "criteria": [
    {
      "name": "factuality",
      "description": "How accurate is the response?",
      "weight": 2.0,
      "rubric": {
        "1": "Multiple factual errors",
        "3": "Mostly accurate with minor issues",
        "5": "Completely accurate"
      }
    },
    {
      "name": "clarity",
      "description": "How clear and understandable is the response?",
      "weight": 1.0,
      "rubric": {
        "1": "Confusing or incoherent",
        "3": "Understandable with effort",
        "5": "Crystal clear"
      }
    }
  ],
  "global_assertions": [
    {
      "name": "mentions OpenJury",
      "type": "contains",
      "value": "OpenJury"
    },
    {
      "name": "does not report an internal error",
      "type": "not_contains",
      "value": "Internal Server Error",
      "case_sensitive": false
    }
  ]
}
