{
  "name": "Resume Evaluation Jury",
  "description": "Minimal jury for fetch/score split and crash-recovery demo",
  "score_scale": 5,
  "llm_provider": {
    "provider": "openai_compatible",
    "model_name": "gpt-4o-mini",
    "api_key": "${OPENAI_API_KEY}"
  },
  "jurors": [
    { "name": "Juror A", "weight": 1.0, "temperature": 0.1 },
    { "name": "Juror B", "weight": 1.0, "temperature": 0.1 }
  ],
  "criteria": [
    {
      "name": "helpfulness",
      "description": "Does the response resolve the user's request?",
      "weight": 2.0,
      "rubric": {
        "1": "Does not help",
        "3": "Partially helpful",
        "5": "Fully resolves the request"
      }
    },
    {
      "name": "accuracy",
      "description": "Is the information correct?",
      "weight": 2.0,
      "rubric": {
        "1": "Material errors",
        "3": "Mostly correct",
        "5": "Fully accurate"
      }
    }
  ]
}
